    <!-- ================================================================== -->
    <!-- STATUS TOGGLE BUTTON STYLES (Error/Warning/Info)                  -->
    <!-- Shared base for pill-shaped toggle with icon + text + count badge -->
    <!-- ================================================================== -->

    <Style x:Key="StatusToggleButtonBase" TargetType="ToggleButton">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,3"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="FontSize" Value="{StaticResource AuroraFontSizeBody}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style x:Key="ErrorStatusToggleButton" TargetType="ToggleButton" BasedOn="{StaticResource StatusToggleButtonBase}">
        <Setter Property="Tag" Value="{StaticResource IconErrorCircle}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Root"
                            SnapsToDevicePixels="True"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="14"
                            Padding="{TemplateBinding Padding}">
                        <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Path x:Name="StatusIcon"
                                  Width="{StaticResource AuroraIconSizeMedium}"
                                  Height="{StaticResource AuroraIconSizeMedium}"
                                  Stretch="Uniform"
                                  Fill="{StaticResource AuroraRed}"
                                  Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                  VerticalAlignment="Center"/>
                            <TextBlock x:Name="text" Grid.Column="1" Margin="5,0,4,0"
                                       Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       VerticalAlignment="Center"/>
                            <Border x:Name="BadgeBorder" Grid.Column="2"
                                    MinWidth="20" Height="20"
                                    CornerRadius="10"
                                    Background="{StaticResource NeutralBackground}"
                                    Padding="6,0" VerticalAlignment="Center">
                                <TextBlock x:Name="text_num"
                                           Text="{Binding ErrorCount, Converter={StaticResource NumberToTextConverter}}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{StaticResource AuroraFontSizeSmall}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSubtleBrush}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource HighlightBorder}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource AuroraRed}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AuroraRed}"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryForeground}"/>
                            <Setter TargetName="StatusIcon" Property="Fill" Value="{StaticResource PrimaryForeground}"/>
                            <Setter TargetName="BadgeBorder" Property="Background" Value="#33FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

