<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:CADE.Aurora.Converters">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="AuroraColors.xaml"/>
        <ResourceDictionary Source="AuroraSizes.xaml"/>
        <ResourceDictionary Source="AuroraSpacing.xaml"/>
        <ResourceDictionary Source="AuroraIcons.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <converters:NumberToTextConverter x:Key="NumberToTextConverter"/>

    <!-- ================================================================== -->
    <!-- IMPLICIT DEFAULT BUTTON STYLE (Aurora modern look for all Buttons)  -->
    <!-- ================================================================== -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Height" Value="{StaticResource AuroraButtonHeightNormal}"/>
        <Setter Property="Padding" Value="12,4"/>
        <Setter Property="FontSize" Value="{StaticResource AuroraFontSizeBody}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSubtleBrush}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource HighlightBorder}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource PrimaryBackground}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource PrimaryBackground}"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryForeground}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="{StaticResource AuroraOpacityDisabled}"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================== -->
    <!-- STANDARD AURORA BUTTON SIZES (keyed, based on implicit default)    -->
    <!-- ================================================================== -->

    <Style x:Key="AuroraButtonNormal" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Width" Value="{StaticResource AuroraButtonWidthNormal}"/>
        <Setter Property="Height" Value="{StaticResource AuroraButtonHeightNormal}"/>
    </Style>

    <Style x:Key="AuroraButtonLarge" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Width" Value="{StaticResource AuroraButtonWidthLarge}"/>
        <Setter Property="Height" Value="{StaticResource AuroraButtonHeightNormal}"/>
    </Style>

    <Style x:Key="AuroraButtonSmall" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Width" Value="{StaticResource AuroraButtonWidthSmall}"/>
        <Setter Property="Height" Value="{StaticResource AuroraButtonHeightSmall}"/>
    </Style>

    <Style x:Key="AuroraButtonMini" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Width" Value="{StaticResource AuroraButtonWidthMini}"/>
        <Setter Property="Height" Value="{StaticResource AuroraButtonHeightMini}"/>
    </Style>

    <Style x:Key="AuroraButtonIcon" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Width" Value="{StaticResource AuroraButtonWidthIcon}"/>
        <Setter Property="Height" Value="{StaticResource AuroraButtonHeightNormal}"/>
    </Style>

    <Style x:Key="AuroraButtonIconSmall" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Width" Value="{StaticResource AuroraButtonWidthIconSmall}"/>
        <Setter Property="Height" Value="{StaticResource AuroraButtonHeightMini}"/>
    </Style>

    <!-- ================================================================== -->
    <!-- MODERN ICON + TEXT BUTTON STYLES (horizontal layout)               -->
    <!-- Shared base for buttons with icon on left + text on right          -->
    <!-- ================================================================== -->

    <Style x:Key="AuroraIconButtonBase" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Width" Value="{StaticResource AuroraButtonWidthNormal}"/>
        <Setter Property="Height" Value="{StaticResource AuroraButtonHeightNormal}"/>
        <Setter Property="Margin" Value="{StaticResource AuroraMarginHorizontalSmall}"/>
        <Setter Property="FontSize" Value="{StaticResource AuroraFontSizeBody}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="12,0">
                            <Path x:Name="Icon"
                                  Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                  Width="{StaticResource AuroraIconSizeLarge}"
                                  Height="{StaticResource AuroraIconSizeLarge}"
                                  Stretch="Uniform"
                                  Fill="{TemplateBinding Foreground}"
                                  Margin="0,0,7,0"/>
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       Foreground="{TemplateBinding Foreground}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSubtleBrush}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource HighlightBorder}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource PrimaryBackground}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource PrimaryBackground}"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryForeground}"/>
                            <Setter TargetName="Icon" Property="Fill" Value="{StaticResource PrimaryForeground}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="{StaticResource AuroraOpacityDisabled}"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ToolsButton" TargetType="Button" BasedOn="{StaticResource AuroraIconButtonBase}">
        <Setter Property="Tag" Value="{StaticResource IconTools}"/>
        <Setter Property="Foreground" Value="#BF8C2A"/>
    </Style>

    <Style x:Key="UtilityButton" TargetType="Button" BasedOn="{StaticResource AuroraIconButtonBase}">
        <Setter Property="Tag" Value="{StaticResource IconUtility}"/>
        <Setter Property="Foreground" Value="{StaticResource AuroraGreen}"/>
    </Style>

    <Style x:Key="AboutButton" TargetType="Button" BasedOn="{StaticResource AuroraIconButtonBase}">
        <Setter Property="Tag" Value="{StaticResource IconInfoCircle}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
    </Style>

    <Style x:Key="GenerateButton" TargetType="Button" BasedOn="{StaticResource AuroraIconButtonBase}">
        <Setter Property="Tag" Value="{StaticResource IconLightning}"/>
        <Setter Property="Foreground" Value="#D48A00"/> <!-- Gold/Yellow lightning color -->
    </Style>

    <!-- ================================================================== -->
    <!-- TOOLBAR BUTTONS (icon + text, flexible width)                     -->
    <!-- Shared across DataBrowser, Telescope, and other tool windows      -->
    <!-- ================================================================== -->

    <Style x:Key="ToolBarButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Height" Value="{StaticResource AuroraButtonHeightNormal}"/>
        <Setter Property="MinWidth" Value="{StaticResource AuroraButtonWidthNormal}"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryForeground}"/>
        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path x:Name="IconPath"
                                  Width="15"
                                  Height="15"
                                  Margin="0,0,7,0"
                                  Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                  Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <TextBlock x:Name="Label"
                                       Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSubtleBrush}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource HighlightBorder}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource PrimaryBackground}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource PrimaryBorder}"/>
                            <Setter TargetName="IconPath" Property="Fill" Value="{StaticResource PrimaryForeground}"/>
                            <Setter TargetName="Label" Property="Foreground" Value="{StaticResource PrimaryForeground}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AuroraDropdownButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Height" Value="{StaticResource AuroraButtonHeightNormal}"/>
        <Setter Property="MinWidth" Value="{StaticResource AuroraButtonWidthNormal}"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryForeground}"/>
        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path x:Name="IconPath"
                                  Width="15"
                                  Height="15"
                                  Margin="0,0,7,0"
                                  Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                  Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <TextBlock x:Name="Label"
                                       Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Path x:Name="ArrowPath"
                                  Width="8"
                                  Height="5"
                                  Margin="8,1,0,0"
                                  Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                  Data="{StaticResource IconChevron}"
                                  RenderTransformOrigin="0.5,0.5"
                                  VerticalAlignment="Center">
                                <Path.RenderTransform>
                                    <RotateTransform Angle="90"/>
                                </Path.RenderTransform>
                            </Path>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Tag" Value="{x:Null}">
                            <Setter TargetName="IconPath" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSubtleBrush}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource HighlightBorder}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource PrimaryBackground}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource PrimaryBorder}"/>
                            <Setter TargetName="IconPath" Property="Fill" Value="{StaticResource PrimaryForeground}"/>
                            <Setter TargetName="ArrowPath" Property="Fill" Value="{StaticResource PrimaryForeground}"/>
                            <Setter TargetName="Label" Property="Foreground" Value="{StaticResource PrimaryForeground}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LoggerToolBarButton" TargetType="Button" BasedOn="{StaticResource ToolBarButton}">
        <Setter Property="MinWidth" Value="{StaticResource AuroraButtonWidthLarge}"/>
        <Setter Property="Foreground" Value="{StaticResource AuroraGreen}"/>
        <Setter Property="Tag" Value="{StaticResource IconLogger}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsDataLogging}" Value="True">
                <Setter Property="Content" Value="Stop Logging"/>
                <Setter Property="Foreground" Value="{StaticResource AuroraRed}"/>
                <Setter Property="Tag" Value="{StaticResource IconLoggerActive}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ToolBarFieldLabel" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
    </Style>

    <!-- ================================================================== -->
    <!-- GREEN TOGGLE SWITCH (iOS-style ON/OFF)                             -->
    <!-- ================================================================== -->

    <Style x:Key="GreenToggleSwitch" TargetType="ToggleButton">
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="BackgroundBorder"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            CornerRadius="13"
                            Background="#B0B0B0"
                            SnapsToDevicePixels="True">
                        <Border x:Name="Thumb"
                                Width="22"
                                Height="22"
                                CornerRadius="11"
                                Background="White"
                                HorizontalAlignment="Left"
                                Margin="2,0,0,0"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.3" Direction="270"/>
                            </Border.Effect>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="BackgroundBorder" Property="Background" Value="{StaticResource AuroraGreen}"/>
                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                            <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="BackgroundBorder" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================== -->
    <!-- GLOBAL CONTROL PILL BUTTONS (Start/Pause/Stop/Hold All)            -->
    <!-- ================================================================== -->

    <Style x:Key="GlobalControlButtonBase" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="MinWidth" Value="{StaticResource AuroraButtonWidthLarge}"/>
        <Setter Property="Height" Value="42"/>
        <Setter Property="Margin" Value="3"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="19"
                            SnapsToDevicePixels="True">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="14,0">
                            <Path x:Name="IconPath"
                                  Width="14"
                                  Height="14"
                                  Stretch="Uniform"
                                  Fill="{TemplateBinding Foreground}"
                                  Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                  Margin="0,0,12,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{TemplateBinding Foreground}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Setter TargetName="IconPath" Property="Fill" Value="White"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StartAllButton" TargetType="Button" BasedOn="{StaticResource GlobalControlButtonBase}">
        <Setter Property="Background" Value="#F0F9F1"/>
        <Setter Property="BorderBrush" Value="#D4EDD8"/>
        <Setter Property="Foreground" Value="{StaticResource AuroraGreen}"/>
        <Setter Property="Tag" Value="{StaticResource IconPlay}"/>
    </Style>

    <Style x:Key="PauseAllButton" TargetType="Button" BasedOn="{StaticResource GlobalControlButtonBase}">
        <Setter Property="Background" Value="#FFFBF0"/>
        <Setter Property="BorderBrush" Value="#FDEAC6"/>
        <Setter Property="Foreground" Value="{StaticResource AuroraYellow}"/>
        <Setter Property="Tag" Value="{StaticResource IconPause}"/>
    </Style>

    <Style x:Key="HoldAllButton" TargetType="Button" BasedOn="{StaticResource GlobalControlButtonBase}">
        <Setter Property="Background" Value="#F0F4FA"/>
        <Setter Property="BorderBrush" Value="#D4E0F0"/>
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Tag" Value="{StaticResource IconHoldVariant}"/>
    </Style>

    <Style x:Key="StopAllButton" TargetType="Button" BasedOn="{StaticResource GlobalControlButtonBase}">
        <Setter Property="Background" Value="#FEF4F4"/>
        <Setter Property="BorderBrush" Value="#FCDADA"/>
        <Setter Property="Foreground" Value="{StaticResource AuroraRed}"/>
        <Setter Property="Tag" Value="{StaticResource IconStop}"/>
    </Style>

    <!-- ================================================================== -->
    <!-- SMALL ICON BUTTONS (Pure Run/Pause/Stop/Hold)                      -->
    <!-- ================================================================== -->

    <Style x:Key="PureRunButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Width" Value="{StaticResource AuroraButtonSizeIconSmall}"/>
        <Setter Property="Height" Value="{StaticResource AuroraButtonSizeIconSmall}"/>
        <Setter Property="Margin" Value="{StaticResource AuroraMarginHorizontalSmall}"/>
        <Setter Property="ToolTip" Value="Start"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="#F0F9F1"/>
        <Setter Property="BorderBrush" Value="#D4EDD8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <Path x:Name="path"
                              Width="12" Height="12"
                              Stretch="Uniform"
                              Data="{StaticResource IconPlay}"
                              Fill="{StaticResource AuroraGreen}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AuroraGreen}"/>
                            <Setter TargetName="border" Property="Background" Value="#E0F3E2"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AuroraGreen}"/>
                            <Setter TargetName="path" Property="Fill" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PurePauseButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Width" Value="{StaticResource AuroraButtonSizeIconSmall}"/>
        <Setter Property="Height" Value="{StaticResource AuroraButtonSizeIconSmall}"/>
        <Setter Property="Margin" Value="{StaticResource AuroraMarginHorizontalSmall}"/>
        <Setter Property="ToolTip" Value="Pause"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="#FFFBF0"/>
        <Setter Property="BorderBrush" Value="#FDEAC6"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <Path x:Name="path"
                              Width="12" Height="12"
                              Stretch="Uniform"
                              Data="{StaticResource IconPause}"
                              Fill="{StaticResource AuroraYellow}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AuroraYellow}"/>
                            <Setter TargetName="border" Property="Background" Value="#FEF7E5"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AuroraYellow}"/>
                            <Setter TargetName="path" Property="Fill" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PureStopButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Width" Value="{StaticResource AuroraButtonSizeIconSmall}"/>
        <Setter Property="Height" Value="{StaticResource AuroraButtonSizeIconSmall}"/>
        <Setter Property="Margin" Value="{StaticResource AuroraMarginHorizontalSmall}"/>
        <Setter Property="ToolTip" Value="Stop"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="#FEF4F4"/>
        <Setter Property="BorderBrush" Value="#FCDADA"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <Path x:Name="path"
                              Width="12" Height="12"
                              Stretch="Uniform"
                              Data="{StaticResource IconStop}"
                              Fill="{StaticResource AuroraRed}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AuroraRed}"/>
                            <Setter TargetName="border" Property="Background" Value="#FDE8E8"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AuroraRed}"/>
                            <Setter TargetName="path" Property="Fill" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PureHoldButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Width" Value="{StaticResource AuroraButtonSizeIconSmall}"/>
        <Setter Property="Height" Value="{StaticResource AuroraButtonSizeIconSmall}"/>
        <Setter Property="Margin" Value="{StaticResource AuroraMarginHorizontalSmall}"/>
        <Setter Property="ToolTip" Value="Hold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="#F0F4FA"/>
        <Setter Property="BorderBrush" Value="#D4E0F0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <Path x:Name="path"
                              Width="12" Height="12"
                              Stretch="Uniform"
                              Data="{StaticResource IconHold}"
                              Fill="{StaticResource AccentBrush}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            <Setter TargetName="border" Property="Background" Value="#E8F0F8"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBrush}"/>
                            <Setter TargetName="path" Property="Fill" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================== -->
    <!-- SPECIALIZED BUTTON STYLES (legacy maintained for compatibility)     -->
    <!-- ================================================================== -->

    <Style x:Key="LoggerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Foreground" Value="{StaticResource SecondaryForeground}"/>
        <Setter Property="Background" Value="{StaticResource SecondaryBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SecondaryBorder}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border SnapsToDevicePixels="True"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            Background="{TemplateBinding Background}">
                        <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Path x:Name="path" Margin="0,2,0,0" Stretch="Fill"
                                  Width="{StaticResource AuroraIconSizeXLarge}"
                                  Height="{StaticResource AuroraIconSizeXLarge}"
                                  Grid.Row="0"
                                  Data="{StaticResource IconLogger}"
                                  Fill="{StaticResource AuroraGreen}"/>
                            <TextBlock x:Name="text" Grid.Row="1"
                                       FontSize="11"
                                       LineStackingStrategy="BlockLineHeight"
                                       LineHeight="11"
                                       Margin="6,2,6,6"
                                       Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       MaxWidth="80"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBorder}"/>
                            <Setter Property="Background" Value="{StaticResource HighlightBackground}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBackground}"/>
                            <Setter Property="Background" Value="{StaticResource PrimaryBackground}"/>
                            <Setter TargetName="path" Property="Fill" Value="{StaticResource PrimaryForeground}"/>
                            <Setter TargetName="text" Property="Foreground" Value="{StaticResource PrimaryForeground}"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding IsDataLogging}" Value="True">
                            <Setter TargetName="path" Property="Data" Value="{StaticResource IconLoggerActive}"/>
                            <Setter TargetName="path" Property="Fill" Value="#c40a17"/>
                            <Setter TargetName="path" Property="Width" Value="18"/>
                            <Setter TargetName="path" Property="Height" Value="18"/>
                            <Setter TargetName="text" Property="Text" Value="Stop&#x0a;Logging"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

