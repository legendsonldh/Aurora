<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="AuroraColors.xaml"/>
        <ResourceDictionary Source="AuroraSizes.xaml"/>
        <ResourceDictionary Source="AuroraActionCard.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="FluentAppRoot" TargetType="{x:Type Grid}">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F7FAFE" Offset="0"/>
                    <GradientStop Color="#EEF4FA" Offset="0.58"/>
                    <GradientStop Color="#F8FBFF" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="FluentCommandBar" TargetType="{x:Type Border}">
        <Setter Property="MinHeight" Value="48"/>
        <Setter Property="Margin" Value="10,2,10,0"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="18"
                                  Direction="270"
                                  Opacity="0.08"
                                  ShadowDepth="4"
                                  Color="#223044"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FluentWorkspaceCard" TargetType="{x:Type Border}">
        <Setter Property="Margin" Value="10"/>
        <Setter Property="Padding" Value="1"/>
        <Setter Property="Background" Value="{StaticResource LightBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="22"
                                  Direction="270"
                                  Opacity="0.10"
                                  ShadowDepth="6"
                                  Color="#243447"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FluentToolbarButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="Margin" Value="4,0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="FluentToolbarPrimaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource FluentToolbarButton}">
        <Setter Property="Background" Value="{StaticResource PrimaryBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryForeground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBorder}"/>
    </Style>


</ResourceDictionary>
