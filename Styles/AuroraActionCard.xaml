<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:CADE.Aurora.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/CADE.Aurora;component/Styles/AuroraColors.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/CADE.Aurora;component/Styles/AuroraSizes.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/CADE.Aurora;component/Styles/AuroraSpacing.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="{x:Type controls:AuroraActionCard}">
        <Setter Property="Width" Value="{StaticResource AuroraActionCardWidth}"/>
        <Setter Property="Height" Value="{StaticResource AuroraActionCardHeight}"/>
        <Setter Property="Margin" Value="{StaticResource AuroraMarginLarge}"/>
        <Setter Property="Background" Value="{StaticResource SurfaceRaisedBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Top"/>
        <Setter Property="AccentBrush" Value="{StaticResource PrimaryBorder}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:AuroraActionCard}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14"
                                              Direction="270"
                                              Opacity="0.06"
                                              ShadowDepth="3"
                                              Color="#25364A"/>
                        </Border.Effect>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Accent Bar -->
                            <Border Grid.Column="0" 
                                    Background="{TemplateBinding AccentBrush}" 
                                    CornerRadius="10,0,0,10"
                                    Margin="0,2"/>

                            <!-- Icon -->
                            <Border Grid.Column="1" 
                                    Width="48" 
                                    Height="48" 
                                    CornerRadius="12"
                                    Background="{StaticResource AccentSubtleBrush}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                                <Image Width="32" Height="32" 
                                       Source="{TemplateBinding IconSource}" 
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>

                            <!-- Content Area -->
                            <StackPanel Grid.Column="2" Margin="5,16,16,16" VerticalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Title}" 
                                           Foreground="{StaticResource TextPrimary}" 
                                           FontSize="15" 
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                
                                <TextBlock Text="{TemplateBinding Description}" 
                                           Foreground="{StaticResource TextSecondary}" 
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           LineHeight="18"
                                           Opacity="0.85"
                                           Margin="0,0,0,8">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                
                                <!-- Additional Content (e.g. CheckBox) -->
                                <ContentPresenter Content="{TemplateBinding AdditionalContent}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSubtleBrush}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource HighlightBorder}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource PrimaryBorder}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
