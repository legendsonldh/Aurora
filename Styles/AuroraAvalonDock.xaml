<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:dockControls="clr-namespace:AvalonDock.Controls;assembly=AvalonDock">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="AuroraColors.xaml"/>
        <ResourceDictionary Source="AuroraSizes.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Style for Document Tab Items (like the Participant tab) -->
    <Style TargetType="{x:Type dockControls:LayoutDocumentTabItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="Padding" Value="14,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Margin" Value="0,0,2,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type dockControls:LayoutDocumentTabItem}">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="BgBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8,8,0,0"
                                BorderBrush="{StaticResource SurfaceBorder}"
                                BorderThickness="1,1,1,0"/>
                        
                        <!-- Bottom accent bar for selected tab -->
                        <Border x:Name="AccentBar"
                                Height="3"
                                VerticalAlignment="Bottom"
                                Background="Transparent"
                                Margin="1,0,1,0"/>

                        <StackPanel Orientation="Horizontal" Margin="{TemplateBinding Padding}">
                            <!-- Icon Support -->
                            <Image x:Name="Icon"
                                   Source="{Binding Model.IconSource, RelativeSource={RelativeSource TemplatedParent}}"
                                   Width="14" Height="14"
                                   Margin="0,0,8,0"
                                   Visibility="Visible"/>
                            
                            <ContentPresenter x:Name="Content"
                                              ContentSource="Content"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </StackPanel>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Use DataTrigger on Model.IsSelected since AvalonDock's TabItems are bound to models -->
                        <DataTrigger Binding="{Binding Model.IsSelected, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                            <Setter TargetName="BgBorder" Property="Background" Value="{StaticResource SurfaceRaisedBackground}"/>
                            <Setter TargetName="BgBorder" Property="BorderThickness" Value="1,1,1,0"/>
                            <Setter TargetName="AccentBar" Property="Background" Value="{StaticResource AccentBrush}"/>
                            <Setter TargetName="Content" Property="TextElement.FontWeight" Value="SemiBold"/>
                            <Setter TargetName="Content" Property="TextElement.Foreground" Value="{StaticResource TextPrimary}"/>
                            <Setter Property="Panel.ZIndex" Value="1"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BgBorder" Property="Background" Value="{StaticResource AccentSubtleBrush}"/>
                            <Setter TargetName="Content" Property="TextElement.Foreground" Value="{StaticResource TextPrimary}"/>
                        </Trigger>
                        <!-- Hide icon if IconSource is null -->
                        <DataTrigger Binding="{Binding Model.IconSource, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                            <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Style for Anchorable Tab Items (Console, Properties, etc.) -->
    <Style TargetType="{x:Type dockControls:LayoutAnchorableTabItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type dockControls:LayoutAnchorableTabItem}">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="BgBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4,4,0,0"/>
                        <Border x:Name="AccentBar"
                                Height="2"
                                VerticalAlignment="Bottom"
                                Background="Transparent"/>
                        <ContentPresenter x:Name="Content"
                                          Margin="{TemplateBinding Padding}"
                                          ContentSource="Content"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding Model.IsSelected, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                            <Setter TargetName="BgBorder" Property="Background" Value="{StaticResource SurfaceRaisedBackground}"/>
                            <Setter TargetName="AccentBar" Property="Background" Value="{StaticResource AccentBrush}"/>
                            <Setter TargetName="Content" Property="TextElement.FontWeight" Value="SemiBold"/>
                            <Setter TargetName="Content" Property="TextElement.Foreground" Value="{StaticResource TextPrimary}"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BgBorder" Property="Background" Value="{StaticResource AccentSubtleBrush}"/>
                            <Setter TargetName="Content" Property="TextElement.Foreground" Value="{StaticResource TextPrimary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
